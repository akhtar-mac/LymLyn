# Supabase project URL — same value as backend's SUPABASE_URL
VITE_SUPABASE_URL="000"

# Supabase anon/public key — Project Settings > API > anon public (safe for frontend)
VITE_SUPABASE_ANON_KEY="000"

# Backend API base URL — e.g. http://localhost:5000 in dev, real domain in production
VITE_API_BASE_URL="000"

# Razorpay public key ID — same value as backend's RAZORPAY_KEY_ID, safe for frontend checkout widget
VITE_RAZORPAY_KEY_ID="000"
