# Supabase project URL — found in Supabase Dashboard > Project Settings > API
SUPABASE_URL="000"

# Supabase service role key — Project Settings > API > service_role (SECRET, backend only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY="000"

# Razorpay test/live key ID — Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID="000"

# Razorpay key secret — same location as above
RAZORPAY_KEY_SECRET="000"

# Razorpay webhook secret — Razorpay Dashboard > Settings > Webhooks (set when you create the webhook)
RAZORPAY_WEBHOOK_SECRET="000"

# Pexels API key — pexels.com/api, free signup, used only in the dev seed script
PEXELS_API_KEY="000"

# Port the Express server runs on locally
PORT="000"
